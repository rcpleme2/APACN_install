# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Chave secreta para sessões Flask (obrigatório em produção – gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-por-uma-chave-aleatoria-segura

# Porta do servidor (padrão: 5000)
PORT=5000
